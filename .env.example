# Model Provider: "openai" or "hf"
MODEL_PROVIDER=hf

# If MODEL_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL_NAME=gpt-4o

# If MODEL_PROVIDER=hf
HF_TOKEN=hf_...
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=meta-llama/Llama-3.3-70B-Instruct

# Task to run (single-label-classify | multi-label-classify | ad-policy-compliance | thread-moderation-hard)
MODERATION_TASK=single-label-classify

# Benchmark name for logs
BENCHMARK=meta-content-moderation
